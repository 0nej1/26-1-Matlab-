style = input('연결의 형태(직렬=a 또는 병렬=b)을 입력하시오','s');
n9 = input('저항의 개수를 입력하시오');
R = input('각 저항값을 배열의 형태로 입력하시오.[1 2 3 ...]');
result9 = 0;
if style == 'a'
    for i9=1:n9
        result9 = result9 + R(i9);
    end
elseif style == 'b'
    for i9 = 1:n9
        result9 = result9 + 1/R(i9);
    end
    result9 = 1/result9;
end
disp(result9);
